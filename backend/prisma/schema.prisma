generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(uuid())
  name         String
  email        String      @unique
  passwordHash String      @map("password_hash")
  role         UserRole    @default(USER)
  ecoPoints    Int         @default(0) @map("eco_points")
  xp           Int         @default(0)
  level        Int         @default(1)
  streak       Int         @default(0)
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  activities   Activity[]
  address      UserAddress?
  driver       DriverProfile?
  petActions   PetAction[]
  pet          Pet?
  scans        Scan[]

  @@map("users")
}

model District {
  id        String   @id @default(uuid())
  name      String
  city      String?
  province  String?
  provinceCode String? @map("province_code")
  cityCode     String? @map("city_code")
  districtCode String? @unique @map("district_code")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  drivers         DriverProfile[]
  processingSites ProcessingSite[]
  userAddresses   UserAddress[]
  wasteSchedules  WasteSchedule[]

  @@unique([name, city])
  @@map("districts")
}

model DriverProfile {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  vehiclePlate String   @unique @map("vehicle_plate")
  vehicleType  String?  @map("vehicle_type")
  districtId   String   @map("district_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  district District @relation(fields: [districtId], references: [id], onDelete: Restrict)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([districtId])
  @@map("collector_profiles")
}

model UserAddress {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  districtId    String   @map("district_id")
  address       String
  latitude      Float
  longitude     Float
  frontPhotoUrl String?  @map("front_photo_url")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  district District @relation(fields: [districtId], references: [id], onDelete: Restrict)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([districtId])
  @@map("user_addresses")
}

model WasteSchedule {
  id            String   @id @default(uuid())
  districtId    String?  @map("district_id")
  wasteCategory String   @map("waste_category")
  pickupDay     String   @map("pickup_day")
  pickupTime    String   @map("pickup_time")
  instruction   String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  district District? @relation(fields: [districtId], references: [id], onDelete: SetNull)

  @@index([districtId])
  @@map("waste_schedules")
}

model ProcessingSite {
  id                      String         @id @default(uuid())
  districtId              String?        @map("district_id")
  name                    String
  address                 String
  latitude                Float
  longitude               Float
  photoUrl                String?        @map("photo_url")
  acceptedWasteCategories Json           @map("accepted_waste_categories")
  capacityStatus          CapacityStatus @default(AVAILABLE) @map("capacity_status")
  createdAt               DateTime       @default(now()) @map("created_at")
  updatedAt               DateTime       @updatedAt @map("updated_at")

  district District? @relation(fields: [districtId], references: [id], onDelete: SetNull)

  @@index([districtId])
  @@map("processing_sites")
}

model Pet {
  id          String      @id @default(uuid())
  userId      String      @unique @map("user_id")
  name        String      @default("Leafy")
  level       Int         @default(1)
  xp          Int         @default(0)
  nextLevelXp Int         @default(100) @map("next_level_xp")
  health      Int         @default(80)
  happiness   Int         @default(80)
  hunger      Int         @default(30)
  cleanliness Int         @default(80)
  mood        String      @default("happy")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  actions     PetAction[]
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("pets")
}

model Scan {
  id         String        @id @default(uuid())
  userId     String        @map("user_id")
  category   WasteCategory
  label      String
  confidence Int
  isValid    Boolean       @default(false) @map("is_valid")
  ecoPoints  Int           @default(0) @map("eco_points")
  xpReward   Int           @default(0) @map("xp_reward")
  imageUrl   String?       @map("image_url")
  latitude   Float?
  longitude  Float?
  createdAt  DateTime      @default(now()) @map("created_at")
  activities Activity[]
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("scans")
}

model PetAction {
  id         String        @id @default(uuid())
  userId     String        @map("user_id")
  petId      String        @map("pet_id")
  actionType PetActionType @map("action_type")
  ecoCost    Int           @default(0) @map("eco_cost")
  xpReward   Int           @default(0) @map("xp_reward")
  createdAt  DateTime      @default(now()) @map("created_at")
  activities Activity[]
  pet        Pet           @relation(fields: [petId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("pet_actions")
}

model Activity {
  id          String       @id @default(uuid())
  userId      String       @map("user_id")
  type        ActivityType
  title       String
  meta        String
  detail      String?
  scanId      String?      @map("scan_id")
  petActionId String?      @map("pet_action_id")
  createdAt   DateTime     @default(now()) @map("created_at")
  petAction   PetAction?   @relation(fields: [petActionId], references: [id])
  scan        Scan?        @relation(fields: [scanId], references: [id])
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("activities")
}

model RecyclingFacility {
  id          String       @id @default(uuid())
  name        String
  type        FacilityType
  address     String
  latitude    Float
  longitude   Float
  description String?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@map("recycling_facilities")
}

enum UserRole {
  USER
  DRIVER
  ADMIN
}

enum CapacityStatus {
  AVAILABLE
  NEAR_FULL
  FULL
  OVERLOADED
}

enum WasteCategory {
  ORGANIK
  ANORGANIK
  B3
}

enum ActivityType {
  SCAN
  PET
  PROFILE
}

enum PetActionType {
  FEED
  PLAY
  BATH
}

enum FacilityType {
  BANK_SAMPAH
  TPS3R
  DROPBOX_B3
  KOMPOSTER
  LAINNYA
}
