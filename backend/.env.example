PORT=5000
NODE_ENV=development
# Local PostgreSQL example:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nodewaste?schema=public"
# Vercel + Supabase should use the Supabase pooler URL, not db.<project>.supabase.co:5432:
# DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10
CORS_ORIGIN=http://localhost:5173,https://nodewaste-seven.vercel.app
